# QLens AI - Environment Variables Example
# Copy to .env for local development. Never commit real secrets.

NODE_ENV=development
DATABASE_URL="file:./dev.db"
REDIS_URL=redis://localhost:6379

# Apps
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
API_PORT=3001
GATEWAY_PORT=3002
API_BASE_URL=http://localhost:3001/api
ALLOWED_ORIGINS=http://localhost:3000

# Required secrets in production
JWT_SECRET=replace-with-strong-random-value
JWT_REFRESH_SECRET=replace-with-strong-random-value
API_KEY_HASH_SECRET=replace-with-strong-random-value
API_SERVICE_SECRET=replace-with-strong-random-value

# Email provider
RESEND_API_KEY=replace-with-email-provider-key

# Internal model service
INTERNAL_MODEL_BASE_URL=http://127.0.0.1:1930
INTERNAL_MODEL_API_KEY=replace-with-internal-model-key

# Payment provider
MIDTRANS_SERVER_KEY=replace-with-midtrans-server-key
MIDTRANS_CLIENT_KEY=replace-with-midtrans-client-key
MIDTRANS_ENVIRONMENT=sandbox
MIDTRANS_SNAP_BASE_URL=https://app.sandbox.midtrans.com/snap/v2/vtweb

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Abuse prevention
DISPOSABLE_EMAIL_BLOCKLIST=true
MAX_REGISTRATIONS_PER_IP_PER_DAY=5
FREE_TIER_MAX_ACTIVE_KEYS=1
