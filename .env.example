# ==========================================
# QLens AI - Environment Variables
# ==========================================

# Database
DATABASE_URL=postgresql://qlens:qlens_dev_password_2026@localhost:5432/qlens_ai

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-random-64-char-hex-string-here
JWT_REFRESH_SECRET=change-me-to-different-random-string-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (Resend)
RESEND_API_KEY=rs_xxxxxxxxxxxxxxxxxxxxx

# Admin
ADMIN_EMAIL=admin@qlens.ai
ADMIN_PASSWORD=QlensAdmin2026!

# Payment (Midtrans)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_ENVIRONMENT=sandbox

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# API Gateway
GATEWAY_URL=http://localhost:3002
INTERNAL_MODEL_SERVICE_URL=http://localhost:1930

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Abuse Prevention
DISPOSABLE_EMAIL_BLOCKLIST=true
MAX_REGISTRATIONS_PER_IP_PER_DAY=5
FREE_TIER_MAX_ACTIVE_KEYS=1

# Node
NODE_ENV=development
